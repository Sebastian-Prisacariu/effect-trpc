{
  "name": "effect-trpc",
  "version": "0.1.0",
  "description": "tRPC-style ergonomics built on Effect RPC + Effect Atom",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server/handler.d.ts",
      "import": "./dist/server/handler.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@effect/platform": ">=0.70.0",
    "@effect/rpc": ">=0.50.0",
    "@effect-atom/atom-react": ">=0.1.0",
    "effect": ">=3.12.0",
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@effect/platform": "^0.70.0",
    "@effect/rpc": "^0.50.0",
    "@effect-atom/atom-react": "^0.1.0",
    "@types/react": "^18.2.0",
    "effect": "^3.12.0",
    "react": "^18.2.0",
    "typescript": "^5.7.0"
  },
  "keywords": [
    "effect",
    "effect-ts",
    "trpc",
    "rpc",
    "effect-atom",
    "react",
    "typescript"
  ],
  "author": "Sebastian Prisacariu",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Sebastian-Prisacariu/effect-trpc.git"
  }
}
