{
  "name": "effect-trpc",
  "version": "1.0.0",
  "description": "End-to-end typesafe APIs with Effect",
  "type": "module",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/dts/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/dts/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./client": {
      "types": "./dist/dts/client.d.ts",
      "import": "./dist/esm/client.js",
      "require": "./dist/cjs/client.js"
    },
    "./server": {
      "types": "./dist/dts/server.d.ts",
      "import": "./dist/esm/server.js",
      "require": "./dist/cjs/server.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/server.ts src/client.ts --format esm,cjs --dts --out-dir dist",
    "test": "vitest",
    "test:types": "tsc --noEmit",
    "typecheck": "vitest typecheck"
  },
  "peerDependencies": {
    "@effect-atom/atom": "^0.5.0",
    "@effect-atom/atom-react": "^0.5.0",
    "@effect/platform": "^0.70.0",
    "@effect/rpc": "^0.73.2",
    "effect": "^3.0.0",
    "react": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "@effect-atom/atom-react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@effect-atom/atom": "^0.5.0",
    "@effect-atom/atom-react": "^0.5.0",
    "@effect/platform": "^0.70.0",
    "@effect/rpc": "^0.73.2",
    "@effect/vitest": "^0.15.0",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.0.0",
    "effect": "^3.12.0",
    "jsdom": "^28.1.0",
    "react": "^19.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "keywords": [
    "effect",
    "trpc",
    "rpc",
    "typesafe",
    "api"
  ],
  "license": "MIT",
  "dependencies": {
    "@effect/experimental": "^0.58.0",
    "scheduler": "^0.27.0"
  }
}
