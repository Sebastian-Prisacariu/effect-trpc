{
  "name": "effect-trpc",
  "version": "0.1.0",
  "description": "tRPC-style ergonomics for Effect-based applications",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest"
  },
  "peerDependencies": {
    "effect": "^3.0.0"
  },
  "devDependencies": {
    "effect": "^3.12.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.0"
  },
  "keywords": [
    "effect",
    "effect-ts",
    "trpc",
    "rpc",
    "typescript"
  ],
  "author": "Sebastian Prisacariu",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Sebastian-Prisacariu/effect-trpc.git"
  }
}
